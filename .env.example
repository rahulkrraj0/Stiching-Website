# ─────────────────────────────────────────────
# SilaiGhar environment variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Generate a random secret key (run once):
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Admin login
ADMIN_USERNAME=admin
# Generate the hash (run once):
#   python3 -c "from werkzeug.security import generate_password_hash('your-password')"
ADMIN_PASSWORD_HASH=scrypt:32768:8:1$rgotg4un7ngPSDmH$4eed79b89b6aaf3b96df62ba7dd2e33d7632c25c731aa0c35fe54f17be6044df806f9af9971449aa65d1944a94f94c87bf7c47cc335bea0439fb994d2308fc02

# Your live domain (no trailing slash)
SITE_URL=https://www.silaighar.in

# Gunicorn bind (for production server)
HOST=0.0.0.0
PORT=8000
